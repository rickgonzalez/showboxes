# Copy to .env.local and fill in.

# Postgres connection string. You supply this.
DATABASE_URL="postgresql://user:pass@host:5432/showboxes"

# Anthropic API key. Used for both Managed Agents (Agent 1) and
# the Messages API (Agent 2).
ANTHROPIC_API_KEY=""

# The Managed Agents environment slug that this deployment uses.
# On first boot the server provisions an environment with this name
# if one doesn't already exist; the id gets written to the
# ManagedAgentEnvironment table.
MANAGED_AGENTS_ENVIRONMENT_SLUG="showboxes-dev"

# Google Cloud Text-to-Speech (Neural2). Path to a service-account JSON
# file with `serviceusage.serviceUsageConsumer` (or broader) on the project
# where the Cloud Text-to-Speech API is enabled. Used by /api/tts/google.
GOOGLE_APPLICATION_CREDENTIALS=""
GOOGLE_CLOUD_PROJECT=""

# Public origin of the app — used to build magic-link URLs. No trailing slash.
# In dev this is typically http://localhost:3001; in prod it's https://codesplain.io.
APP_URL="http://localhost:3001"

# Resend API key + verified sender. `AUTH_EMAIL_FROM` must be an address on a
# domain you've verified in Resend (e.g. "Codesplain <auth@codesplain.io>").
RESEND_API_KEY=""
AUTH_EMAIL_FROM="Codesplain <auth@codesplain.io>"

# Vercel Cron secret — guards /api/cron/* routes from external callers.
# Vercel sets this automatically when you configure cron jobs; for local
# testing you can leave it blank (the guard is skipped when unset).
CRON_SECRET=""
