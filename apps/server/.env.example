# Copy to .env.local and fill in.

# Postgres connection string. You supply this.
DATABASE_URL="postgresql://user:pass@host:5432/showboxes"

# Anthropic API key. Used for both Managed Agents (Agent 1) and
# the Messages API (Agent 2).
ANTHROPIC_API_KEY=""

# The Managed Agents environment slug that this deployment uses.
# On first boot the server provisions an environment with this name
# if one doesn't already exist; the id gets written to the
# ManagedAgentEnvironment table.
MANAGED_AGENTS_ENVIRONMENT_SLUG="showboxes-dev"

# Google Cloud Text-to-Speech (Neural2). Path to a service-account JSON
# file with `serviceusage.serviceUsageConsumer` (or broader) on the project
# where the Cloud Text-to-Speech API is enabled. Used by /api/tts/google.
GOOGLE_APPLICATION_CREDENTIALS=""
GOOGLE_CLOUD_PROJECT=""
