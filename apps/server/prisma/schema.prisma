// Showboxes server schema — minimum viable for v1 (public repos, no auth).
// Clerk users, orgs, private-repo vaults come later.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// One row per analyze invocation. If a user re-analyzes the same repo,
// we create a new row — the player's cache in localStorage decides
// whether to surface the old one or call for a fresh run.
model Analysis {
  id        String    @id @default(cuid())
  repoUrl   String
  commitSha String?
  // Managed Agents session that produced (or is producing) this analysis.
  sessionId String?   @unique
  status    String    // 'running' | 'ready' | 'error'
  // Content-addressed fingerprint of the Agent 1 definition (model +
  // system prompt) that produced this row. Lets the UI tell runs apart
  // when the agent is being iterated on.
  agentVersion String?
  // The AnalysisJSON produced by submit_code_analysis. Null until status='ready'.
  data      Json?
  // Trace of the effective tunables for this run — captures the 1a triage
  // signals + the user's mode pick + the derived 1b budgets/prose bands.
  // See docs/AGENT-1-TUNABLES.md §5 and lib/agents/trace-mode.ts.
  tunables  Json?
  // Per-stage cost blobs captured at completion. Shape: StageCost[] from
  // lib/costs/rollup.ts — one entry for the analysis session, optionally
  // one for the triage session that preceded it. Scripts derived from
  // this Analysis read these forward into their own rollup.
  stageCosts Json?
  // The User who started this run. Nullable for pre-auth rows and server-
  // initiated runs. Populated from the session on /api/analyze entry.
  userId         String?
  // CreditReservation held for this run. Cleared on settle/release but
  // left populated for audit — ledger entries reference it via refId.
  reservationId  String?
  // Actual credits debited when the reservation settled. Null while the
  // analysis is still running or if it errored before settle.
  debitedCredits Int?
  error     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([repoUrl])
  @@index([status])
  @@index([userId])
}

// One row per successfully generated presentation script. Scripts are
// independent of Analysis — they survive analysis deletion and can be
// replayed on their own. `analysisId` is an advisory pointer back to
// the analysis they were derived from, not a FK/relation, so deleting
// an analysis never cascades into scripts. The repo URL and persona
// are denormalized so the listing dropdown can filter and label
// without a join.
model Script {
  id                String   @id @default(cuid())
  analysisId        String?
  repoUrl           String
  commitSha         String?
  label             String
  persona           String
  status            String   // 'ready' | 'error'
  data              Json     // PresentationScript
  settings          Json     // UserSettings used for generation
  focusInstructions String?
  producerModel     String?
  usage             Json?    // { inputTokens, outputTokens }
  // The User who owns this Script. Nullable for legacy rows; canReadScript
  // treats unowned + private as unreachable. Populated from the session on
  // /api/script entry.
  userId            String?
  // 'private' (owner-only) | 'unlisted' (anyone with shareToken). 'public'
  // is reserved for a future release and currently rejected by canReadScript.
  visibility        String   @default("private")
  // Random 32-byte URL-safe token. Required when visibility='unlisted';
  // null otherwise. Rotating invalidates any existing embeds.
  shareToken        String?  @unique
  error             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([repoUrl])
  @@index([analysisId])
  @@index([createdAt])
  @@index([userId])
  @@index([shareToken])
}

// One row per note/flag captured by a reviewer while watching a script
// play back. Notes are advisory and not FK-linked — they survive script
// deletion. Captured from the player's "flag" button, which pauses the
// scene and records enough context to find it again in pgAdmin or a
// future review UI. No elapsed/time is captured in v1 — scene index + id
// has been enough to locate issues so far.
model ScriptNote {
  id             String   @id @default(cuid())
  scriptId       String?  // advisory FK to Script.id (null for sample scripts)
  scriptLabel    String?  // denormalized Script.label or sample key
  analysisId     String?  // advisory FK to Analysis.id
  repoUrl        String?
  sceneIndex     Int
  sceneId        String
  sceneTemplate  String
  note           String   @db.Text
  // Review workflow state. 'open' when captured; moves to 'in-progress'
  // while a fix is being worked, 'resolved' once the underlying template
  // or prompt change has landed, 'wontfix' if we decide not to act on it.
  status         String   @default("open") // 'open' | 'in-progress' | 'resolved' | 'wontfix'
  // Which layer the reviewer suspects is at fault: 'analysis' (Agent 1
  // picked wrong content / wrong tone), 'script' (Agent 2 picked the
  // wrong template or wrote bad narration/content), 'template' (the
  // rendered primitive is buggy/cramped/overflows). Nullable because
  // older rows predate this column and because the reviewer can skip
  // the tag when unsure.
  suspectArea    String?  // 'analysis' | 'script' | 'template' | null
  createdAt      DateTime @default(now())

  @@index([scriptId])
  @@index([createdAt])
  @@index([status])
  @@index([suspectArea])
}

// One row per Managed Agents environment we provision. Typically just
// one environment per deployment (dev / staging / prod), seeded on first
// boot. The gnome's externalId is stored per-agent elsewhere — this
// table only tracks the environment.
model ManagedAgentEnvironment {
  id         String   @id @default(cuid())
  // The id returned by Anthropic when we provision the environment.
  externalId String   @unique
  name       String
  createdAt  DateTime @default(now())
}

// One row per gnome we sync to Managed Agents. Mirrors the extract-gnome-kit
// pattern at a minimum. For v1 we have exactly one gnome ("code-analysis-gnome"),
// but keeping the table polymorphic makes it trivial to add the Producer
// gnome (Agent 2) later without migrations.
model Gnome {
  id                  String   @id @default(cuid())
  slug                String   @unique
  name                String
  description         String
  defaultModel        String
  // Pre-rendered system prompt template (Handlebars). Stored so edits
  // survive deploys without re-shipping code.
  systemPromptTemplate String   @db.Text
  // External Managed Agent id returned by the provisioning call. Null
  // until first sync succeeds.
  externalAgentId     String?
  // Version of the external agent, bumped on every sync.
  externalAgentVersion Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// The account owner of a credit balance. Email-keyed for MVP; when Clerk
// (or equivalent) lands, migrate by email and add a real auth userId
// alongside. `balance` is a materialized cache — always recomputable by
// summing LedgerEntry.amount for the user.
model User {
  id               String   @id @default(cuid())
  email            String   @unique
  emailVerified    DateTime?
  // Stripe customer id — created on first checkout, reused thereafter.
  stripeCustomerId String?  @unique
  balance          Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  ledgerEntries LedgerEntry[]
  reservations  CreditReservation[]
  purchases     Purchase[]
  sessions      UserSession[]
  magicLinks    MagicLink[]
}

// Append-only credit ledger. Positive = credit in (purchase, grant,
// refund). Negative = debit out (usage, adjustment). Never updated,
// never deleted — balance corrections are written as new entries.
model LedgerEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Int      // signed
  kind      String   // 'purchase' | 'grant' | 'usage' | 'refund' | 'adjustment' | 'reservation_settle'
  refType   String   // 'purchase' | 'grant' | 'analysis' | 'adjustment' | 'reservation'
  refId     String?
  memo      String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([refType, refId])
}

// Held credits that are neither spent nor spendable. Created before
// Agent 1b runs, settled or released when it completes. Create does
// NOT write a LedgerEntry — settle does (signed debit), release does
// not. Available balance = User.balance - sum(held reservations).
model CreditReservation {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  amount        Int      // always positive — the held amount
  refType       String   // 'analysis' for v1
  refId         String   // e.g. Analysis.id
  status        String   // 'held' | 'settled' | 'released' | 'expired'
  // Actual amount debited when this reservation settled; may be less
  // than `amount` if the job cost less than estimated.
  settledAmount Int?
  // Safety net — the reaper auto-releases holds older than this.
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, status])
  @@index([refType, refId])
}

// Stripe purchase attempts. One row per PaymentIntent; flipped from
// `pending` to `succeeded` by the webhook, which also writes the
// corresponding positive LedgerEntry.
model Purchase {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id])
  sku                   String
  credits               Int
  amountUsdCents        Int
  stripePaymentIntentId String   @unique
  status                String   // 'pending' | 'succeeded' | 'failed' | 'refunded'
  creditLedgerEntryId   String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
}

// Magic-link tokens. Opaque, single-use, short-lived. We store only
// the sha256 hash of the token — the raw value lives in the email.
model MagicLink {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

// Server-side session. The cookie carries only the id; everything
// else (user, expiry, last-seen) lives here so sessions can be
// revoked by deleting the row.
model UserSession {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@index([userId])
}
